{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "lockFileMaintenance": {
    "enabled": false
  },
  "ignoreDeps": [
    "io.papermc.paper:paper-api"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "org.incendo:cloud-*"
      ],
      "allowedVersions": "!/SNAPSHOT/"
    }
  ]
}
